# Copy this file to .env (not committed to git) and fill in real values.
# Loaded into the container by docker-compose (env_file) and read by
# app/var/www/YT/config/config.php via getenv().

# SOCKS5 proxy used for domains outside Downloader::DIRECT_ACCESS_DOMAINS.
# Format: socks5://user:pass@host:port (leave empty to disable proxying)
SOCKS5_URL=
